generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "sqlite"
}

model Group {
  id             Int    @id @default(autoincrement())
  name           String @unique
  color          String
  interval       Int
  workers        Int
  stockIfPresent String
  priceLocator   String
  links          Link[]
}

model Link {
  id          Int      @id @default(autoincrement())
  name        String
  url         String
  last        String
  lastPrice   String
  lastError   String?
  lastStock   Boolean
  lastChecked DateTime @default(now())
  lastChanged DateTime @default(now())
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId     Int
}
